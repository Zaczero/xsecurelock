echo "P 15"
echo "Enter password:"

read_counted_input() {
  count=$1
  if head -c 0 >/dev/null 2>&1; then
    head -c "$count"
  else
    dd bs=1 count="$count" 2>/dev/null
  fi
}

read -r ptype len
case "$ptype" in
  p)
    # Trick: reading len+1 characters get the password and the terminating
    # newline - just what we need here.
    if read_counted_input "$((len+1))" |\
        @path_to_pamtester@ @pam_service_name@ "$USER" authenticate \
          >/dev/null 2>&1; then
      echo "i 11"
      echo "I know you."
      exit 0
    else
      echo "e 17"
      echo "Invalid password."
      exit 1
    fi
    ;;
  x)
    exit 1
    ;;
  *)
    echo >&2 "Unexpected packet type."
    exit 1
    ;;
esac
